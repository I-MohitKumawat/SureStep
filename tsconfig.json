{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": [
      "esnext"
    ],
    "jsx": "react-native",
    "strict": true,
    "noImplicitAny": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "app/*": [
        "app/*"
      ],
      "ui/*": [
        "packages/ui/*"
      ],
      "core/*": [
        "packages/core/*"
      ]
    }
  },
  "include": [
    "App.tsx",
    "app/**/*",
    "packages/ui/**/*",
    "packages/core/**/*"
  ],
  "extends": "expo/tsconfig.base.json"
}
